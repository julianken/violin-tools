# Dependencies
node_modules/

# Build output (static assets) — committed lockfile stays, but dist never does
dist/
.next/
out/
build/

# Turborepo task cache + Vitest coverage
.turbo/
coverage/

# Playwright e2e artifacts (S8 soft-launch suite) — reports/traces are CI artifacts
playwright-report/
test-results/
blob-report/
.playwright/

# Terraform (infra/): live state, provider plugins, and the populated tfvars are
# never committed — only infra/terraform.tfvars.example is. The live
# terraform.tfvars may hold real per-deploy values (and, if the alt Cloudflare
# provider path is ever taken, a token), so it stays out of git.
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
terraform.tfvars
*.auto.tfvars
crash.log
crash.*.log

# Misc
.DS_Store
*.log
.env*.local

# Working / internal: plans, scratch, process artifacts — never committed (AGENTS.md → Disclosure & sensitivity)
tmp/

# Session tooling (not part of the app)
.remember/
.superpowers/
.playwright-mcp/

# Claude Code: repo-local agents/skills ARE committed; per-developer settings and agent worktrees are not
.claude/settings.local.json
.claude/worktrees/
.claude/scheduled_tasks.lock

# Cursor: commit shared config (rules/agents/commands) if ever added; ignore per-developer state.
# Do NOT blanket-ignore .cursor/ — that would hide a future committed pointer/config.
.cursor/mcp.json
